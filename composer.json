{
  "name": "adam/adam-membership",
  "description": "Membership management plugin for ADAM (Associacao Desportiva de Airsoft do Mondego).",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": ">=8.2",
    "dompdf/dompdf": "^3.1"
  },
  "require-dev": {
    "wp-coding-standards/wpcs": "^3.1",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "AdamMembership\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AdamMembership\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "phpcs --standard=WordPress --extensions=php .",
    "lint:fix": "phpcbf --standard=WordPress --extensions=php ."
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "sort-packages": true
  }
}
